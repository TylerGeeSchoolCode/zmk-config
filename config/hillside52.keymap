        symbol_layer {
            //                          в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
            //                          в”Ӯ SYMBOL LAYER в”Ӯ
