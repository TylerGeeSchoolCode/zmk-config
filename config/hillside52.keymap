/ {
    // Define a default keymap here.
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            //                       в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®
